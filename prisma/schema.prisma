generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum SyncStatus {
  IDLE
  SYNCING
  ERROR
}

enum SyncJobType {
  INITIAL
  INCREMENTAL
  MANUAL
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ParticipantType {
  FROM
  TO
  CC
  BCC
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  role           UserRole        @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  googleAccounts GoogleAccount[]
  auditLogs      AuditLog[]
  sessions       Session[]
  accounts       Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("nextauth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model GoogleAccount {
  id              String    @id @default(cuid())
  userId          String
  googleId        String    @unique
  email           String
  displayName     String?
  accessToken     String    @db.Text
  refreshToken    String?   @db.Text
  tokenExpiry     DateTime?
  scopes          String?
  isConnected     Boolean   @default(true)
  connectedAt     DateTime  @default(now())
  disconnectedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox Mailbox?

  @@map("google_accounts")
}

model Mailbox {
  id              String     @id @default(cuid())
  googleAccountId String     @unique
  email           String
  historyId       String?
  totalMessages   Int        @default(0)
  syncStatus      SyncStatus @default(IDLE)
  lastSyncAt      DateTime?
  lastError       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  googleAccount    GoogleAccount    @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  threads          Thread[]
  messages         Message[]
  labels           Label[]
  syncJobs         SyncJob[]
  automationEvents AutomationEvent[]

  @@map("mailboxes")
}

model Thread {
  id            String    @id @default(cuid())
  mailboxId     String
  gmailThreadId String
  snippet       String?   @db.Text
  messageCount  Int       @default(0)
  lastMessageAt DateTime?
  isRead        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mailbox  Mailbox   @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([mailboxId, gmailThreadId])
  @@index([mailboxId, lastMessageAt(sort: Desc)])
  @@map("threads")
}

model Message {
  id             String   @id @default(cuid())
  threadId       String?
  mailboxId      String
  gmailMessageId String
  gmailThreadId  String
  subject        String?  @db.Text
  snippet        String?  @db.Text
  fromEmail      String?
  fromName       String?
  toEmails       String?  @db.Text
  ccEmails       String?  @db.Text
  bccEmails      String?  @db.Text
  bodyText       String?  @db.Text
  bodyHtml       String?  @db.Text
  internalDate   DateTime
  labelIds       String[] @default([])
  isRead         Boolean  @default(true)
  isStarred      Boolean  @default(false)
  sizeEstimate   Int?
  headers        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  thread           Thread?           @relation(fields: [threadId], references: [id], onDelete: SetNull)
  mailbox          Mailbox           @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  participants     Participant[]
  attachments      Attachment[]
  automationEvents AutomationEvent[]

  @@unique([mailboxId, gmailMessageId])
  @@index([mailboxId, internalDate(sort: Desc)])
  @@index([gmailThreadId])
  @@map("messages")
}

model Participant {
  id        String          @id @default(cuid())
  messageId String
  email     String
  name      String?
  type      ParticipantType

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([email])
  @@map("participants")
}

model Label {
  id           String  @id @default(cuid())
  mailboxId    String
  gmailLabelId String
  name         String
  type         String  @default("user")
  color        String?

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, gmailLabelId])
  @@map("labels")
}

model Attachment {
  id                String @id @default(cuid())
  messageId         String
  gmailAttachmentId String
  filename          String
  mimeType          String
  size              Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model SyncJob {
  id                String        @id @default(cuid())
  mailboxId         String
  type              SyncJobType
  status            SyncJobStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  messagesProcessed Int           @default(0)
  error             String?       @db.Text
  metadata          Json?
  createdAt         DateTime      @default(now())

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([mailboxId, createdAt(sort: Desc)])
  @@map("sync_jobs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  details   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model AutomationEvent {
  id          String    @id @default(cuid())
  mailboxId   String
  messageId   String?
  eventType   String
  payload     Json?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  mailbox Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([mailboxId, createdAt(sort: Desc)])
  @@map("automation_events")
}
